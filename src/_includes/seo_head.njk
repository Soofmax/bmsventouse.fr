{%- set pageUrl = page.url | url -%}
{%- if pageUrl == '/' -%}
  {%- set canonicalComputed = site.url + '/' -%}
{%- else -%}
  {%- set canonicalComputed = site.url + pageUrl -%}
{%- endif -%}
{%- set canonicalHref = canonical or canonicalComputed -%}
{# Robust hreflang alternates computation #}
{%- set frPath = pageUrl -%}
{%- if pageUrl == '/' -%}
  {%- set enPath = '/en/' -%}
{%- else -%}
  {%- set enPath = '/en' + pageUrl -%}
{%- endif -%}
{%- if (pageUrl | replace('/en/','/')) != pageUrl -%}
  {%- set frPath = pageUrl | replace('/en/','/') -%}
  {%- set enPath = pageUrl -%}
{%- endif -%}
{%- set frHref = site.url + frPath -%}

{# Meta tags essentiels optimisés #}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<meta name="keywords" content="{{ keywords | default('ventousage plateau, sécurisation tournage, logistique audiovisuelle, convoyage véhicules, gardiennage plateau, régie technique, transport spécialisé, autorisations tournage Paris') }}">
<meta name="author" content="{{ site.brand }}">
<meta name="theme-color" content="{{ site.themeColor }}">
<meta name="robots" content="{{ robots | default('index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1') }}">

{# Liens canoniques et hreflang #}
<link rel="canonical" href="{{ canonicalHref }}">
<link rel="alternate" hreflang="fr-FR" href="{{ frHref }}">
<link rel="alternate" hreflang="x-default" href="{{ canonicalHref }}">

{# Script anti-flash pour thème sombre #}
<script>
  (function(){
    try{
      var k='bms-theme-preference';
      var s=localStorage.getItem(k);
      var m=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches;
      var dark=s?s==='dark':m;
      if(dark){
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    }catch(e){ void e; }
  })();
</script>

{# Open Graph / Facebook optimisé #}
<meta property="og:title" content="{{ title | escape }}">
<meta property="og:description" content="{{ description | escape }}">
<meta property="og:url" content="{{ canonicalHref }}">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:image" content="{{ ogImage or (site.url + '/images/og-image.jpg') }}">
<meta property="og:image:width" content="{{ ogImageWidth or '1200' }}">
<meta property="og:image:height" content="{{ ogImageHeight or '630' }}">
<meta property="og:locale" content="fr_FR">
<meta property="og:site_name" content="{{ site.brand }}">
<meta property="fb:app_id" content="{{ site.facebookAppId }}">

{# Twitter Cards optimisé #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="{{ site.twitterHandle }}">
<meta name="twitter:creator" content="{{ site.twitterHandle }}">
<meta name="twitter:title" content="{{ title | escape }}">
<meta name="twitter:description" content="{{ description | escape }}">
<meta name="twitter:image" content="{{ ogImage or (site.url + '/images/og-image.jpg') }}">

{# Preload critique pour performance #}
{% if heroImage and not heroDefer %}
  {% if heroImageMobile %}
<link rel="preload" as="image" imagesrcset="{{ heroImageMobile }} 768w, {{ heroImage }} 1920w" imagesizes="100vw" fetchpriority="high">
  {% else %}
<link rel="preload" as="image" href="{{ heroImage }}" fetchpriority="high">
  {% endif %}
{% endif %}

{# Preload favicon et ressources critiques #}
<link rel="preload" as="image" href="/favicon-32x32.png">
<link rel="preload" href="{{ '/css/style.bundle.css' | fingerprint }}" as="style">

{# Favicon et manifest #}
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="manifest" href="/site.webmanifest">
<link rel="shortcut icon" href="/favicon.ico">

{# CSS et fonts optimisés #}
<link rel="stylesheet" href="{{ '/css/style.bundle.css' | fingerprint }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

{# JSON-LD Schema.org avancé #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "url": "{{ site.url }}",
      "name": "{{ site.brand }}",
      "description": "{{ site.description }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ site.url }}/search/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "{{ site.brand }}",
      "url": "{{ site.url }}",
      "logo": "{{ site.url }}/android-chrome-512x512.png",
      "description": "{{ site.description }}",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "FR",
        "addressLocality": "Paris",
        "addressRegion": "Île-de-France"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+33646005642",
        "contactType": "customer service",
        "availableLanguage": "French"
      },
      "sameAs": [
        "https://www.linkedin.com/company/bms-ventouse",
        "https://www.facebook.com/bmsventouse"
      ]
    },
    {
      "@type": "LocalBusiness",
      "name": "{{ site.brand }}",
      "description": "Spécialiste en ventousage de plateau, sécurisation de tournage et logistique audiovisuelle en France",
      "url": "{{ site.url }}",
      "telephone": "+33646005642",
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "FR",
        "addressLocality": "Paris",
        "addressRegion": "Île-de-France"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "48.8566",
        "longitude": "2.3522"
      },
      "openingHours": "Mo-Su 00:00-23:59",
      "serviceArea": {
        "@type": "Country",
        "name": "France"
      }
    },
    {
      "@type": "Service",
      "name": "Ventousage de Plateau",
      "description": "Service professionnel de ventousage et neutralisation de places de stationnement pour tournages",
      "provider": {
        "@type": "Organization",
        "name": "{{ site.brand }}"
      },
      "areaServed": {
        "@type": "Country",
        "name": "France"
      }
    },
    {
      "@type": "Service",
      "name": "Sécurisation de Tournage",
      "description": "Gardiennage et sécurisation 24h/24 de plateaux de tournage par agents spécialisés",
      "provider": {
        "@type": "Organization",
        "name": "{{ site.brand }}"
      },
      "areaServed": {
        "@type": "Country",
        "name": "France"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Accueil",
          "item": "{{ site.url }}/"
        }
        {%- if breadcrumbs -%}
          {%- for crumb in breadcrumbs -%}
          ,{
            "@type": "ListItem",
            "position": {{ loop.index + 1 }},
            "name": "{{ crumb.name }}",
            "item": "{{ site.url }}{{ crumb.url }}"
          }
          {%- endfor -%}
        {%- endif -%}
      ]
    }
  ]
}
</script>

{# Schema.org spécifique à la page #}
{% if pageType == 'service' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "provider": {
    "@type": "Organization",
    "name": "{{ site.brand }}",
    "url": "{{ site.url }}"
  },
  "areaServed": {
    "@type": "Country",
    "name": "France"
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "EUR"
  }
}
</script>
{% endif %}

{# Meta tags pour performance et accessibilité #}
<meta name="format-detection" content="telephone=no">
<meta name="msapplication-TileColor" content="{{ site.themeColor }}">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

{# DNS prefetch pour performance #}
<link rel="dns-prefetch" href="//fonts.googleapis.com">
<link rel="dns-prefetch" href="//fonts.gstatic.com">
<link rel="dns-prefetch" href="//www.google-analytics.com">