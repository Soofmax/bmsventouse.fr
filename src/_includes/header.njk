<!-- Promo banner should live outside the header to avoid overlap -->
<div class="promo-banner" id="promoBanner">
  <p><strong>Offre de bienvenue :</strong> -15% à tous les nouveaux clients&nbsp;!</p>
</div>

<header class="header" role="banner">
  <div class="container">
    <div class="nav">
      <!-- Branding -->
      <a href="/" class="logo" aria-label="Retour à l'accueil de {{ site.brand }}">
        <img src="/android-chrome-192x192.png" alt="Logo {{ site.brand }}" width="40" height="40">
        <span class="logo-text">
          <span class="bms">BMS</span> <span class="ventouse">Ventouse</span>
        </span>
      </a>

      <!-- Mobile toggle -->
      <button 
        class="hamburger" 
        id="hamburger"
        aria-label="Ouvrir le menu de navigation"
        aria-expanded="false"
        aria-controls="navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Primary navigation -->
      <nav id="navigation" role="navigation" aria-label="Navigation principale">
        <ul id="navLinks" class="nav-links">
          <li><a href="/" class="nav-link{% if activeNav == 'home' %} active{% endif %}">Accueil</a></li>
          <li><a href="/services/" class="nav-link{% if activeNav == 'services' %} active{% endif %}">Services</a></li>
          <li><a href="/realisations/" class="nav-link{% if activeNav == 'realisations' %} active{% endif %}">Références</a></li>
          <li><a href="/contact/" class="nav-link{% if activeNav == 'contact' %} active{% endif %}">Contact</a></li>

          <!-- CTA visible dans le menu mobile -->
          <li class="nav-cta-mobile">
            <a href="/contact/" class="btn btn-primary" data-cta="contact" data-cta-label="Demander un devis (menu)">
              Demander un devis
            </a>
          </li>
        </ul>
      </nav>

      <!-- Utilities (desktop) -->
      <div class="nav-utilities">
        <a href="tel:{{ site.phone | replace(' ', '') }}" class="nav-utility-link" aria-label="Nous appeler">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.11.37 2.3.57 3.58.57a1 1 0 011 1V21a1 1 0 01-1 1C10.07 22 2 13.93 2 3a1 1 0 011-1h3.5a1 1 0 011 1c0 1.28.2 2.47.57 3.58a1 1 0 01-.24 1.01l-2.2 2.2z"/></svg>
          <span class="utility-text">{{ site.phone }}</span>
        </a>

        <button id="themeToggle" class="theme-toggle" aria-pressed="false" title="Basculer le thème (clair/sombre)" aria-label="Basculer le thème">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M12 3a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1Zm0 15a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm8-7a1 1 0 0 1 1 1h1a1 1 0 1 1 0 2h-1a1 1 0 1 1-2 0 1 1 0 0 1 1-1Zm-8 8a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM4 11a1 1 0 0 1 1-1H4a1 1 0 1 0 0 2h1a1 1 0 0 1-1-1Zm12.95-5.536a1 1 0  0 1 1.414 0l.707.707a1 1 0 1 1-1.414 1.414l-.707-.707a1 1 0 0  1 0-1.414ZM6.222 17.778a1 1 0 0 1 1.414 0l.707.707a1 1 0 0  1-1.414 1.414l-.707-.707a1 1 0 0  1 0-1.414Zm12.9 1.414a1 1 0 0  1-1.414 0l-.707-.707a1 1 0 1 1 1.414-1.414l.707.707a1 1 0 0 1 0 1.414ZM6.343 5.464a1 1 0 0 1 0 1.414l-.707.707A1 1 0 1 1 4.222 6.17l.707-.707a1 1 0  0 1 1.414 0Z"/>
          </svg>
        </button>

        <div class="lang-switcher" aria-label="Sélecteur de langue">
          <a href="/" class="lang-link {% if lang == 'fr' %}is-current{% endif %}" aria-current="{% if lang == 'fr' %}page{% else %}false{% endif %}">FR</a>
          <a href="/en/" class="lang-link {% if lang == 'en' %}is-current{% endif %}" aria-current="{% if lang == 'en' %}page{% else %}false{% endif %}">EN</a>
        </div>

        <a href="/contact/" class="btn btn-primary nav-cta" data-cta="contact" data-cta-label="Demander un devis (header)">
          Demander un devis
        </a>
      </div>
    </div>
  </div>
</header>
<div class="nav-overlay" id="navOverlay"></div>