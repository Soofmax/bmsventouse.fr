<header class="header" role="banner">
  <div class="container">
    <div class="nav">
      <a href="/" class="logo" aria-label="Retour à l'accueil de {{ site.brand }}">
        <img src="/android-chrome-192x192.png" alt="Logo {{ site.brand }}" width="40" height="40">
        <span class="logo-text">
          <span class="bms">BMS</span> <span class="ventouse">Ventouse</span>
        </span>
      </a>

      

      <button 
        class="hamburger" 
        id="hamburger"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav id="navigation" role="navigation" aria-label="Main navigation">
        <ul id="navLinks" class="nav-links">
          <li><a href="/" class="nav-link{% if activeNav == 'home' %} active{% endif %}">Accueil</a></li>
          <li class="nav-item has-submenu">
            <a href="/services/" class="nav-link{% if activeNav == 'services' %} active{% endif %}" aria-haspopup="true" aria-expanded="false">Services</a>
            <div class="submenu" aria-label="Sous-menu Services">
              <div class="services-menu">
                <!-- Lien général -->
                <div class="menu-top">
                  <a href="/services/" class="menu-all">
                    <span class="all-icon">📚</span>
                    <span>Tous les services</span>
                  </a>
                </div>

                <!-- Les plus demandés -->
                <div class="menu-section featured">
                  <h4 class="section-title"><span class="section-icon">🔥</span> LES PLUS DEMANDÉS</h4>
                  <a href="/services/ventousage/" class="menu-item">
                    <span class="item-icon">🚧</span>
                    <div class="item-content">
                      <span class="item-name">Ventousage</span>
                      <span class="item-desc">Autorisations &amp; neutralisation</span>
                    </div>
                    <span class="item-badge popular">Populaire</span>
                  </a>
                  <a href="/services/securite-gardiennage/" class="menu-item">
                    <span class="item-icon">🛡️</span>
                    <div class="item-content">
                      <span class="item-name">Sécurité plateau</span>
                      <span class="item-desc">Gardiennage 24/7 spécialisé</span>
                    </div>
                    <span class="item-badge premium">Premium</span>
                  </a>
                </div>

                <!-- Essentiels -->
                <div class="menu-section">
                  <h4 class="section-title"><span class="section-icon">⭐</span> ESSENTIELS</h4>
                  <a href="/services/ventousage/" class="menu-item">
                    <span class="item-icon">🚧</span>
                    <div class="item-content">
                      <span class="item-name">Ventousage</span>
                      <span class="item-desc">Stationnement &amp; signalisation</span>
                    </div>
                  </a>
                  <a href="/services/securite-gardiennage/" class="menu-item">
                    <span class="item-icon">🛡️</span>
                    <div class="item-content">
                      <span class="item-name">Sécurité plateau</span>
                      <span class="item-desc">Agents, contrôle d’accès</span>
                    </div>
                  </a>
                </div>

                <!-- Techniques -->
                <div class="menu-section">
                  <h4 class="section-title"><span class="section-icon">🔧</span> TECHNIQUES</h4>
                  <a href="/services/convoyage/" class="menu-item">
                    <span class="item-icon">🚛</span>
                    <div class="item-content">
                      <span class="item-name">Convoyage</span>
                      <span class="item-desc">Transport sécurisé</span>
                    </div>
                  </a>
                  <a href="/services/regie-materiel/" class="menu-item">
                    <span class="item-icon">🎬</span>
                    <div class="item-content">
                      <span class="item-name">Régie &amp; matériel</span>
                      <span class="item-desc">Coordination technique</span>
                    </div>
                  </a>
                </div>

                <!-- Complémentaires -->
                <div class="menu-section">
                  <h4 class="section-title"><span class="section-icon">➕</span> COMPLÉMENTAIRES</h4>
                  <a href="/services/loges-confort/" class="menu-item">
                    <span class="item-icon">🏠</span>
                    <div class="item-content">
                      <span class="item-name">Loges</span>
                      <span class="item-desc">Espaces talents &amp; équipes</span>
                    </div>
                  </a>
                  <a href="/services/cantine-catering/" class="menu-item">
                    <span class="item-icon">🍽️</span>
                    <div class="item-content">
                      <span class="item-name">Cantine</span>
                      <span class="item-desc">Restauration plateau</span>
                    </div>
                  </a>
                  <a href="/services/logistique-evenementielle/" class="menu-item">
                    <span class="item-icon">🎉</span>
                    <div class="item-content">
                      <span class="item-name">Événementiel</span>
                      <span class="item-desc">Mode, pubs, galas</span>
                    </div>
                  </a>
                  <a href="/services/solutions-packagees/" class="menu-item">
                    <span class="item-icon">📦</span>
                    <div class="item-content">
                      <span class="item-name">Solutions packagées</span>
                      <span class="item-desc">Offres tout-en-un</span>
                    </div>
                    <span class="item-badge new">Nouveau</span>
                  </a>
                </div>

                <!-- CTA -->
                <div class="menu-footer">
                  <a href="/contact/" class="menu-cta">
                    <span class="cta-icon">⚡</span>
                    <span>Devis gratuit sous 2h</span>
                  </a>
                </div>
              </div>
            </div>
          </li>
              <li><a href="/services/convoyage/" class="submenu-link">Convoyage</a></li>
              <li><a href="/services/regie-materiel/" class="submenu-link">Régie &amp; matériel</a></li>

              <li class="submenu-divider" role="separator" aria-hidden="true"></li>

              <!-- Complémentaires -->
              <li class="submenu-heading" aria-hidden="true">Complémentaires</li>
              <li><a href="/services/loges-confort/" class="submenu-link">Loges</a></li>
              <li><a href="/services/cantine-catering/" class="submenu-link">Cantine</a></li>
              <li><a href="/services/logistique-evenementielle/" class="submenu-link">Événementiel</a></li>
              <li><a href="/services/solutions-packagees/" class="submenu-link">Solutions packagées</a></li>
            </ul>
          </li>
          <li><a href="/realisations/" class="nav-link{% if activeNav == 'realisations' %} active{% endif %}">Références</a></li>
          <li><a href="/contact/" class="nav-link{% if activeNav == 'contact' %} active{% endif %}">Contact</a></li>

          </ul>
      </nav>

      <button id="themeToggle" class="theme-toggle" aria-pressed="false" title="Basculer le thème (clair/sombre)" aria-label="Basculer le thème">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="currentColor" d="M12 3a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1Zm0 15a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm8-7a1 1 0 0 1 1 1h1a1 1 0 1 1 0 2h-1a1 1 0 1 1-2 0 1 1 0 0 1 1-1Zm-8 8a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM4 11a1 1 0 0 1 1-1H4a1 1 0 1 0 0 2h1a1 1 0 0 1-1-1Zm12.95-5.536a1 1 0 0 1 1.414 0l.707.707a1 1 0 1 1-1.414 1.414l-.707-.707a1 1 0 0 1 0-1.414ZM6.222 17.778a1 1 0 0 1 1.414 0l.707.707a1 1 0 0 1-1.414 1.414l-.707-.707a1 1 0 0 1 0-1.414Zm12.9 1.414a1 1 0 0 1-1.414 0l-.707-.707a1 1 0 1 1 1.414-1.414l.707.707a1 1 0 0 1 0 1.414ZM6.343 5.464a1 1 0 0 1 0 1.414l-.707.707A1 1 0 1 1 4.222 6.17l.707-.707a1 1 0 0 1 1.414 0Z"/>
        </svg>
      </button>

      
    </div>
  </div>
  <div class="promo-banner" id="promoBanner">
    <p><strong>Offre de bienvenue :</strong> -15% à tous les nouveaux clients&nbsp;!</p>
  </div>
</header>
<!-- Sentinel pour gérer l'état shrink du header via IntersectionObserver -->
<div id="headerSentinel" aria-hidden="true" style="position:relative; height: 1px;"></div>
<div class="nav-overlay" id="navOverlay"></div>